+static bool psp_xgmi_extended_peer_links_valid(struct psp_xgmi_topology_info *topology,
+	struct ta_xgmi_cmd_get_extend_peer_link_info *link_info)
+{
+	bool has_link = false;
+	int i, j;
+
+	if (!topology || topology->num_nodes <= 1)
+		return true;
+
+	for (i = 0; i < topology->num_nodes; i++) {
+		uint8_t num_links = link_info->nodes[i].num_links;
+
+		if (num_links > TA_XGMI__MAX_PORT_NUM)
+			return false;
+
+		for (j = 0; j < num_links; j++)
+			if (link_info->nodes[i].port_num[j].src_xgmi_port_num ||
+			    link_info->nodes[i].port_num[j].dst_xgmi_port_num)
+				has_link = true;
+	}
+
+	return has_link;
+}
